NODE_ENV=development
PORT=3000
API_PREFIX=/api

# PostgreSQL
# Docker: postgresql://postgres:postgres@localhost:5432/wedding_contracts
# מקומי (Homebrew): postgresql://localhost/wedding_contracts  (לאחר: createdb wedding_contracts)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wedding_contracts

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
